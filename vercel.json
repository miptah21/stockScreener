{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 300,
      "memory": 1024
    }
  },
  "excludeFiles": [
    ".venv/**",
    "__pycache__/**",
    "scripts/**",
    ".git/**",
    "*.pyc",
    ".env"
  ]
}
